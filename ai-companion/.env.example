# AI Provider Keys (get from provider dashboards)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
ELEVENLABS_API_KEY=
INTERNAL_SERVICE_KEY=choose-your-own-key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
