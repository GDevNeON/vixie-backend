# Database Configuration
POSTGRES_DB=vixie_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring
SPRING_PROFILES_ACTIVE=default

# JWT (MUST match user-auth service — same shared secret)
JWT_SECRET=change-me-please-very-very-secret-jwt-key-change-me

# AI Provider Keys (get from provider dashboards)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
ELEVENLABS_API_KEY=

# Internal Service Key (MUST match user-auth — same shared key)
INTERNAL_SERVICE_KEY=change-me-internal-service-key

# User-Auth Service URL (for cross-service calls)
USER_AUTH_BASE_URL=http://localhost:8080
